<!DOCTYPE html>
<html lang="en">
<head>
  <title>Chat</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }

    :root {
      --bg:     #0b0f19;
      --surf:   #151b2e;
      --surf2:  #1c2540;
      --bd:     rgba(255,255,255,0.08);
      --acc:    #5b6ef5;
      --txt:    #e8ecf7;
      --muted:  #8892b0;
      --me:     #3d4fd6;
      --them:   #1c2540;
      --HH:     62px;
      --IH:     64px;
    }

    html, body { height:100%; overflow:hidden; }

    body {
      background: var(--bg);
      font-family: 'DM Sans', sans-serif;
      color: var(--txt);
      /* body fixed prevents iOS rubber-band scroll shifting header */
      position: fixed;
      width: 100%;
      top: 0; left: 0;
    }

    /* ─── HEADER: fixed, never moves ─── */
    #hdr {
      position: fixed;
      top: 0; left: 0; right: 0;
      height: var(--HH);
      background: var(--surf);
      border-bottom: 1px solid var(--bd);
      display: flex; align-items: center; gap: 12px;
      padding: 0 16px;
      z-index: 200;
    }
    .av {
      width:38px; height:38px; border-radius:50%;
      background:var(--acc);
      display:flex; align-items:center; justify-content:center;
      font-size:14px; font-weight:600; color:#fff; flex-shrink:0;
    }
    .hi { flex:1; min-width:0; }
    .hn { font-size:16px; font-weight:600; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .hs { font-size:12px; color:#4ade80; margin-top:1px; }
    .hr {
      font-size:12px; color:var(--muted);
      background:var(--surf2); padding:4px 10px;
      border-radius:20px; border:1px solid var(--bd);
      white-space:nowrap; flex-shrink:0;
    }

    /* ─── MESSAGES: fills between header and input bar ─── */
    #msgs {
      position: fixed;
      top: var(--HH); left: 0; right: 0; bottom: var(--IH);
      overflow-y: auto; overflow-x: hidden;
      -webkit-overflow-scrolling: touch;
      padding: 10px 12px 6px;
      list-style: none;
      display: flex; flex-direction: column;
      z-index: 10;
    }
    #msgs::-webkit-scrollbar { width:3px; }
    #msgs::-webkit-scrollbar-thumb { background:rgba(255,255,255,0.1); border-radius:10px; }

    .m {
      max-width:78%; padding:9px 13px; margin:2px 0;
      border-radius:18px; font-size:15px; line-height:1.45;
      word-break:break-word;
    }
    .me   { background:var(--me); color:#fff; margin-left:auto; border-bottom-right-radius:4px; }
    .them { background:var(--them); border:1px solid var(--bd); margin-right:auto; border-bottom-left-radius:4px; }
    .un   { font-size:11px; font-weight:600; opacity:0.6; margin-bottom:2px; }
    .me .un { color:rgba(255,255,255,0.75); }
    .them .un { color:#7c8cf8; }
    .ts   { font-size:10px; opacity:0.38; text-align:right; margin-top:2px; }
    .sys  {
      text-align:center; font-size:12px; color:var(--muted);
      background:rgba(255,255,255,0.04);
      border-radius:20px; padding:3px 14px;
      align-self:center; margin:6px 0;
    }

    /* ─── TYPING indicator ─── */
    #typ {
      position: fixed;
      left:0; right:0;
      bottom: var(--IH);
      padding: 2px 16px 2px;
      font-size:12px; color:var(--muted); font-style:italic;
      background: var(--bg);
      min-height:18px;
      z-index:150;
      transition: transform 0.05s linear;
    }

    /* ─── INPUT BAR: fixed to bottom, moves up with keyboard ─── */
    #bar {
      position: fixed;
      bottom: 0; left: 0; right: 0;
      height: var(--IH);
      background: var(--surf);
      border-top: 1px solid var(--bd);
      display: flex; align-items: center; gap: 8px;
      padding: 0 12px;
      padding-bottom: env(safe-area-inset-bottom, 0px);
      z-index: 200;
      transition: transform 0.05s linear;
    }

    #inp {
      flex:1; height:42px; padding:0 16px;
      border-radius:21px; border:1px solid var(--bd);
      background:var(--surf2); color:var(--txt);
      font-size:15px; font-family:'DM Sans',sans-serif;
      outline:none; transition:border-color 0.15s;
    }
    #inp:focus { border-color:var(--acc); }
    #inp::placeholder { color:var(--muted); }

    #snd {
      width:42px; height:42px; border-radius:50%; border:none;
      background:var(--acc); color:#fff;
      display:flex; align-items:center; justify-content:center;
      cursor:pointer; flex-shrink:0;
      transition:opacity 0.15s, transform 0.1s;
    }
    #snd:active { opacity:0.8; transform:scale(0.91); }
    #snd svg { width:18px; height:18px; }
  </style>
</head>
<body>

<div id="hdr">
  <div class="av" id="av">?</div>
  <div class="hi">
    <div class="hn" id="hn"><%= usrnm %></div>
    <div class="hs">online</div>
  </div>
  <div class="hr" id="hr">#room</div>
</div>

<ul id="msgs"></ul>

<div id="typ"></div>

<div id="bar">
  <input id="inp" type="text" placeholder="Type a message…" autocomplete="off" />
  <button id="snd" aria-label="Send">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="22" y1="2" x2="11" y2="13"/>
      <polygon points="22 2 15 22 11 13 2 9 22 2"/>
    </svg>
  </button>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
const socket = io();
const ME   = "<%= usrnm %>";
const ROOM = "<%= room %>";

const inp  = document.getElementById('inp');
const msgs = document.getElementById('msgs');
const typ  = document.getElementById('typ');
const bar  = document.getElementById('bar');
const typEl= document.getElementById('typ');

document.getElementById('av').textContent = ME.slice(0,2).toUpperCase();
document.getElementById('hn').textContent = ME;
document.getElementById('hr').textContent = '# ' + ROOM;

socket.emit('join-room', { username: ME, room: ROOM });

/* ── Keep input bar above keyboard using visualViewport ── */
if (window.visualViewport) {
  function onVVResize() {
    const vv   = window.visualViewport;
    const diff = window.innerHeight - vv.offsetTop - vv.height;
    bar.style.transform  = `translateY(-${diff}px)`;
    typEl.style.transform= `translateY(-${diff}px)`;
    scrollBottom();
  }
  window.visualViewport.addEventListener('resize', onVVResize);
  window.visualViewport.addEventListener('scroll', onVVResize);
}

function scrollBottom() {
  msgs.scrollTop = msgs.scrollHeight;
}

/* ── Send ── */
function send() {
  const v = inp.value.trim();
  if (!v) return;
  socket.emit('chat message', v);
  socket.emit('stop-typing');
  inp.value = '';
  /* intentionally do NOT blur — keyboard stays up */
  scrollBottom();
}

document.getElementById('snd').addEventListener('click', send);
inp.addEventListener('keydown', e => {
  if (e.key === 'Enter') { e.preventDefault(); send(); }
});

/* ── Receive messages ── */
let lastSender = null;

socket.on('chat message', data => {
  const li   = document.createElement('li');
  const isMe = data.user === ME;
  const same = lastSender === data.user;
  li.className = 'm ' + (isMe ? 'me' : 'them');

  const t = new Date().toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'});
  li.innerHTML =
    (!same ? `<div class="un">${esc(data.user)}</div>` : '') +
    `<div>${esc(data.message)}</div>` +
    `<div class="ts">${t}</div>`;

  msgs.appendChild(li);
  lastSender = data.user;
  scrollBottom();
});

socket.on('user-connected',    m => { lastSender=null; sys(m); });
socket.on('user-disconnected', m => { lastSender=null; sys(m); });

function sys(m) {
  const d = document.createElement('div');
  d.className='sys'; d.textContent=m;
  msgs.appendChild(d); scrollBottom();
}

/* ── Typing ── */
let tUsers = new Set(), tTO;

inp.addEventListener('input', () => socket.emit('typing'));
inp.addEventListener('keyup',  () => {
  clearTimeout(tTO);
  tTO = setTimeout(() => socket.emit('stop-typing'), 1000);
});

socket.on('typing',      u => { if(u!==ME){ tUsers.add(u);    renderT(); }});
socket.on('stop-typing', u => { tUsers.delete(u); renderT(); });

function renderT() {
  typ.textContent = tUsers.size ? [...tUsers].join(', ') + ' typing…' : '';
}

function esc(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}
</script>
</body>
</html>
