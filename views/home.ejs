<!DOCTYPE html>
<html>
<head>
  <title>Chat</title>
  <link rel="stylesheet" href="/css/home.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter&display=swap" rel="stylesheet">
</head>

<body>

<header>
  <%= usrnm %>
</header>

<ul id="messages"></ul>
<div id="typing"></div>

<form id="form">
  <input id="input" placeholder="Type message..." autocomplete="off"/>
  <button>Send</button>
</form>

<script src="/socket.io/socket.io.js"></script>

<script>
const socket = io();

const username = "<%= usrnm %>";
const room = "<%= room %>";

const input = document.getElementById('input');
const form = document.getElementById('form');
const messages = document.getElementById('messages');
const typingDiv = document.getElementById('typing');

socket.emit('join-room', { username, room });

form.addEventListener('submit', e => {
  e.preventDefault();
  if (input.value.trim()) {
    socket.emit('chat message', input.value);
    socket.emit('stop-typing');
    input.value = '';
  }
});

socket.on('chat message', data => {
  const li = document.createElement('li');
  li.classList.add('message', data.user === username ? 'me' : 'other');

  li.innerHTML = `
    <div class="username">${data.user}</div>
    ${data.message}
  `;

  messages.appendChild(li);
  messages.scrollTop = messages.scrollHeight;
});

socket.on('user-connected', msg => addSystem(msg));
socket.on('user-disconnected', msg => addSystem(msg));

function addSystem(msg) {
  const div = document.createElement('div');
  div.classList.add('system');
  div.textContent = msg;
  messages.appendChild(div);
}

/* typing */
let typingUsers = new Set();

input.addEventListener('input', () => socket.emit('typing'));

socket.on('typing', user => {
  if (user !== username) {
    typingUsers.add(user);
    renderTyping();
  }
});

socket.on('stop-typing', user => {
  typingUsers.delete(user);
  renderTyping();
});

function renderTyping() {
  typingDiv.textContent =
    typingUsers.size ? [...typingUsers].join(', ') + " typing..." : "";
}

let timeout;
input.addEventListener('keyup', () => {
  clearTimeout(timeout);
  timeout = setTimeout(() => {
    socket.emit('stop-typing');
  }, 1000);
});
</script>

</body>
</html>