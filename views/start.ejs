<!DOCTYPE html>
<html lang="en">
<head>
  <title>Join Chat</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }
    :root {
      --bg:    #0b0f19;
      --surf:  #151b2e;
      --surf2: #1c2540;
      --bd:    rgba(255,255,255,0.08);
      --acc:   #5b6ef5;
      --txt:   #e8ecf7;
      --muted: #8892b0;
    }
    html { height:100%; }
    body {
      min-height:100dvh;
      background:var(--bg);
      font-family:'DM Sans',sans-serif;
      color:var(--txt);
      display:flex; align-items:center; justify-content:center;
      padding:24px 16px;
    }
    .card {
      width:100%; max-width:420px;
      background:var(--surf);
      border:1px solid var(--bd);
      border-radius:24px;
      padding:36px 28px;
    }
    .logo {
      width:52px; height:52px; border-radius:16px;
      background:var(--acc);
      display:flex; align-items:center; justify-content:center;
      margin:0 auto 20px;
    }
    .logo svg { width:26px; height:26px; color:#fff; }
    h2 { text-align:center; font-size:22px; font-weight:600; margin-bottom:6px; }
    .sub { text-align:center; font-size:14px; color:var(--muted); margin-bottom:28px; }
    label { display:block; font-size:13px; font-weight:500; color:var(--muted); margin-bottom:6px; letter-spacing:0.3px; }
    .field { margin-bottom:14px; }
    input {
      width:100%; padding:14px 16px;
      border-radius:14px; border:1px solid var(--bd);
      background:var(--surf2); color:var(--txt);
      font-size:16px; font-family:'DM Sans',sans-serif;
      outline:none; transition:border-color 0.15s;
    }
    input:focus { border-color:var(--acc); }
    input::placeholder { color:var(--muted); }
    button {
      width:100%; margin-top:8px; padding:16px;
      border-radius:14px; border:none;
      background:var(--acc); color:#fff;
      font-size:16px; font-weight:600;
      font-family:'DM Sans',sans-serif;
      cursor:pointer; display:flex; align-items:center; justify-content:center; gap:8px;
      transition:opacity 0.15s, transform 0.1s;
    }
    button:active { opacity:0.85; transform:scale(0.98); }
    button svg { width:18px; height:18px; }
    @media(min-width:768px){ .card{ padding:44px 40px; } }
  </style>
</head>
<body>
<div class="card">
  <div class="logo">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
    </svg>
  </div>
  <h2>Join a Room</h2>
  <p class="sub">Enter your name and room ID to start chatting</p>
  <form action="/home" method="POST">
    <div class="field">
      <label for="nm">Your name</label>
      <input type="text" id="nm" name="name" placeholder="e.g. Alex" required autocomplete="off" />
    </div>
    <div class="field">
      <label for="rm">Room ID</label>
      <input type="text" id="rm" name="room" placeholder="e.g. general" required autocomplete="off" />
    </div>
    <button type="submit">
      Join Room
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12"/>
        <polyline points="12 5 19 12 12 19"/>
      </svg>
    </button>
  </form>
</div>
</body>
</html>
