<!DOCTYPE html>
<html>
<head>
  <title>Join Chat</title>
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after {
      margin: 0; padding: 0;
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
    }

    :root {
      --bg: #0b0f19;
      --surface: #151b2e;
      --surface2: #1c2540;
      --border: rgba(255,255,255,0.08);
      --accent: #5b6ef5;
      --text: #e8ecf7;
      --text2: #8892b0;
    }

    html, body {
      height: 100%;
      background: var(--bg);
      font-family: 'DM Sans', sans-serif;
      color: var(--text);
    }

    body {
      min-height: 100dvh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px 16px;
    }

    /* ── CARD ── */
    .card {
      width: 100%;
      max-width: 420px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 36px 28px;
    }

    /* ── LOGO MARK ── */
    .logo {
      width: 52px;
      height: 52px;
      border-radius: 16px;
      background: var(--accent);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 20px;
    }

    .logo svg {
      width: 28px;
      height: 28px;
      color: white;
    }

    h2 {
      text-align: center;
      font-size: 22px;
      font-weight: 600;
      margin-bottom: 6px;
    }

    .subtitle {
      text-align: center;
      font-size: 14px;
      color: var(--text2);
      margin-bottom: 28px;
    }

    /* ── FORM ── */
    .field {
      margin-bottom: 14px;
    }

    label {
      display: block;
      font-size: 13px;
      font-weight: 500;
      color: var(--text2);
      margin-bottom: 6px;
      letter-spacing: 0.3px;
    }

    input {
      width: 100%;
      padding: 14px 16px;
      border-radius: 14px;
      border: 1px solid var(--border);
      background: var(--surface2);
      color: var(--text);
      font-size: 16px;
      font-family: 'DM Sans', sans-serif;
      outline: none;
      transition: border-color 0.2s;
    }

    input:focus { border-color: var(--accent); }
    input::placeholder { color: var(--text2); }

    /* ── BUTTON ── */
    button {
      width: 100%;
      margin-top: 8px;
      padding: 16px;
      border-radius: 14px;
      border: none;
      background: var(--accent);
      color: white;
      font-size: 16px;
      font-weight: 600;
      font-family: 'DM Sans', sans-serif;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      transition: opacity 0.15s, transform 0.1s;
    }

    button:active { opacity: 0.85; transform: scale(0.98); }

    button svg { width: 18px; height: 18px; }

    @media (min-width: 768px) {
      .card { padding: 44px 40px; }
    }
  </style>
</head>

<body>

<div class="card">
  <!-- Logo -->
  <div class="logo">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
    </svg>
  </div>

  <h2>Join a Room</h2>
  <p class="subtitle">Enter your name and room ID to start chatting</p>

  <form action="/home" method="POST">
    <div class="field">
      <label for="name">Your name</label>
      <input type="text" id="name" name="name" placeholder="e.g. Alex" required autocomplete="off" />
    </div>

    <div class="field">
      <label for="room">Room ID</label>
      <input type="text" id="room" name="room" placeholder="e.g. general" required autocomplete="off" />
    </div>

    <button type="submit">
      Join Room
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12"></line>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </button>
  </form>
</div>

</body>
</html>
